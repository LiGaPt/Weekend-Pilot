{
  "name": "weekend-pilot-web-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run dev:customer",
    "dev:customer": "vite --config vite.config.ts",
    "dev:internal": "vite --config vite.internal.config.ts",
    "build": "npm run build:customer && npm run build:internal",
    "build:customer": "tsc -b && vite build --config vite.config.ts",
    "build:internal": "tsc -b && vite build --config vite.internal.config.ts",
    "preview": "vite preview --config vite.config.ts",
    "preview:internal": "vite preview --config vite.internal.config.ts",
    "test": "vitest --config vitest.config.ts --exclude e2e/**",
    "e2e": "node ./scripts/run-e2e.mjs",
    "e2e:headed": "node ./scripts/run-e2e.mjs --headed",
    "e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^26.1.0",
    "vitest": "^3.2.0"
  }
}
