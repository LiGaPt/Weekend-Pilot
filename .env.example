APP_NAME=WeekendPilot
APP_ENV=local
APP_VERSION=0.1.0
LOG_LEVEL=INFO

LLM_ENABLED=false
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_ID=
LLM_TIMEOUT=10
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=weekend-pilot
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=
LANGCHAIN_TRACING_V2=true
LOCAL_TRACE_BUFFER_PATH=var/traces/weekendpilot-traces.jsonl

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/weekend_pilot
REDIS_URL=redis://localhost:6379/0

AMAP_MAPS_API_KEY=
BAIDU_MAP_API_KEY=
